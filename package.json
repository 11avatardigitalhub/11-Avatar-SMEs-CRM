{
  "name": "11avatar-crm",
  "version": "3.0.0",
  "description": "11 Avatar Digital Hub - India's #1 Revenue Operating System for SMEs. Complete CRM with Lead Management, Pipeline, Revenue Tracking, GST Invoices, WhatsApp Integration, and Multi-Tenant RBAC.",
  "main": "index.html",
  "scripts": {
    "start": "serve .",
    "dev": "serve . -l 3000",
    "build": "echo 'Static multi-page app - no build step required'",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "prettier --check 'src/**/*.{js,css,html}'",
    "lint:fix": "prettier --write 'src/**/*.{js,css,html}'",
    "deploy": "git push origin main",
    "deploy:firebase": "firebase deploy --only hosting,firestore:rules,firestore:indexes,functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "seed": "node scripts/seed-data.js",
    "audit": "lighthouse https://11avatardigitalhub.github.io/11-Avatar-SMEs-CRM/ --output html --output-path ./reports/lighthouse.html",
    "format": "prettier --write '**/*.{js,html,css,json,md}'",
    "format:check": "prettier --check '**/*.{js,html,css,json,md}'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/11avatardigitalhub/11-Avatar-SMEs-CRM.git"
  },
  "keywords": [
    "crm", "indian-crm", "sme-crm", "revenue-management",
    "lead-management", "pipeline-management", "gst-invoices",
    "whatsapp-business-api", "sales-crm", "pwa", "firebase",
    "multi-tenant", "rbac", "indian-business", "free-crm",
    "msme", "small-business", "revenue-operating-system"
  ],
  "author": {
    "name": "11 Avatar Digital Hub",
    "email": "info@11avatardigitalhub.cloud",
    "url": "https://11avatardigitalhub.github.io/11-Avatar-SMEs-CRM/"
  },
  "contributors": [
    {
      "name": "11 Avatar Team",
      "email": "info@11avatardigitalhub.cloud"
    }
  ],
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/11avatardigitalhub/11-Avatar-SMEs-CRM/issues",
    "email": "support@11avatardigitalhub.cloud"
  },
  "homepage": "https://11avatardigitalhub.github.io/11-Avatar-SMEs-CRM/",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": [
    "> 1%", "last 2 versions", "not dead", "not ie 11",
    "Chrome >= 80", "Firefox >= 75", "Safari >= 13",
    "Edge >= 80", "Android >= 8", "iOS >= 13"
  ],
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "serve": "^14.2.0",
    "lighthouse": "^11.0.0"
  },
  "dependencies": {
    "firebase": "^10.7.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.6.0",
    "firebase-tools": "^13.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.js", "**/*.spec.js"],
    "collectCoverageFrom": ["src/js/**/*.js", "!src/js/config/firebase.js", "!**/node_modules/**"],
    "coverageThreshold": {
      "global": { "branches": 60, "functions": 65, "lines": 70, "statements": 70 }
    },
    "setupFilesAfterFramework": ["<rootDir>/tests/setup.js"],
    "verbose": true,
    "coverageReporters": ["text", "text-summary", "html", "lcov"]
  },
  "prettier": {
    "semi": true, "singleQuote": true, "tabWidth": 2,
    "trailingComma": "es5", "printWidth": 100,
    "bracketSpacing": true, "arrowParens": "always", "endOfLine": "lf"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/11avatardigitalhub"
  }
}