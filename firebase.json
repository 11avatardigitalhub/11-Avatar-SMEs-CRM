{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/functions/**",
      "**/tests/**",
      "**/docs/**",
      "**/scripts/**",
      "**/database/**",
      "**/.github/**",
      "**/package.json",
      "**/package-lock.json",
      "**/README.md",
      "**/LICENSE",
      "**/.gitignore",
      "**/.nojekyll"
    ],
    "rewrites": [],
    "redirects": [
      {
        "source": "/",
        "destination": "/index.html",
        "type": 301
      },
      {
        "source": "/404",
        "destination": "/404.html",
        "type": 301
      },
      {
        "source": "/offline",
        "destination": "/offline.html",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(self)"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|svg|ico|webp|gif)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          }
        ]
      },
      {
        "source": "**/*.@(woff|woff2|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "manifest.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "./"
          }
        ]
      },
      {
        "source": "**/*.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          },
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false,
    "appAssociation": "AUTO",
    "i18n": {
      "root": "/"
    }
  },
  "firestore": {
    "rules": "database/firestore.rules",
    "indexes": "database/firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "region": "asia-south1",
    "memory": "256MB",
    "timeoutSeconds": 60,
    "minInstances": 0,
    "maxInstances": 10,
    "vpcConnector": null,
    "ingressSettings": "ALLOW_ALL",
    "environmentVariables": {
      "NODE_ENV": "production",
      "FIREBASE_PROJECT_ID": "avatar-wa-dual-crm"
    }
  },
  "storage": {
    "rules": "database/storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    },
    "hosting": {
      "port": 5000
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  },
  "database": {
    "rules": "database/database.rules.json"
  },
  "remoteconfig": {
    "template": "remoteconfig.template.json"
  }
}