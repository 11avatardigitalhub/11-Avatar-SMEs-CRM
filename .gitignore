# ==========================================
# 11 AVATAR DIGITAL HUB
# .gitignore - Git Ignore Rules
# Version: 2.0 Enterprise
# ==========================================
# Purpose:
# - Exclude sensitive files from version control
# - Ignore build artifacts and dependencies
# - Prevent accidental commits of large files
# - Keep repository clean and efficient
# ==========================================

# ==========================================
# NODE.JS / NPM
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm
.eslintcache
*.tsbuildinfo

# ==========================================
# ENVIRONMENT & CONFIGURATION
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
local.properties

# ==========================================
# FIREBASE
# ==========================================
.firebase/
.firebaserc
firebase-debug.log
firebase-debug.*.log
ui-debug.log

# Firebase service account keys (CRITICAL!)
*-service-account.json
*serviceAccountKey.json
*firebase-adminsdk*.json
google-services.json
GoogleService-Info.plist

# ==========================================
# CLOUDFLARE
# ==========================================
.wrangler/
wrangler.toml
.cloudflare/
*.worker.js.map

# ==========================================
# IDE & EDITORS
# ==========================================

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.project
.classpath
.settings/
.metadata/

# NetBeans
nbproject/
nbbuild/
dist/
nbdist/

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# Atom
.atom/

# ==========================================
# OPERATING SYSTEMS
# ==========================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
*.nfs*

# ==========================================
# BUILD & OUTPUT
# ==========================================
build/
dist/
output/
out/
_site/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
coverage/
*.tsbuildinfo

# ==========================================
# LOGS & TEMPORARY
# ==========================================
*.log
logs/
*.tmp
*.temp
tmp/
temp/
*.swp
*.swo
*.bak
*.cache
.cache/

# ==========================================
# DATABASE & BACKUPS
# ==========================================
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
backups/
*.backup
*.sql.gz
dump.sql

# ==========================================
# COMPRESSED FILES
# ==========================================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bz2
*.gz

# ==========================================
# MEDIA & LARGE FILES
# ==========================================
# (Keep only source files, not generated media)
# Uncomment if needed:
# *.mp4
# *.mp3
# *.wav
# *.mov
# *.avi
# *.mkv

# ==========================================
# SECURITY & SENSITIVE FILES
# ==========================================

# Certificates
*.pem
*.crt
*.key
*.csr
*.p12
*.pfx
*.jks
*.keystore
*.truststore
certificates/
ssl/

# API Keys & Tokens (CRITICAL!)
api-keys.json
tokens.json
secrets.json
credentials.json
*secret*
*credential*
*api-key*

# ==========================================
# TESTING & COVERAGE
# ==========================================
coverage/
.coverage/
.nyc_output/
.jest/
*.lcov
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.pytest_cache/

# ==========================================
# MISCELLANEOUS
# ==========================================
*.pid
*.seed
*.pid.lock
.sass-cache/
*.css.map
*.js.map
*.min.js
*.min.css

# ==========================================
# PROJECT SPECIFIC
# ==========================================

# Old backup files
Old Backup/
*.old
*.orig

# Generated icons (keep source only)
assets/images/icons/generated/

# Seed data exports (keep script only)
seed-data-export.json
sample-data-export.json

# Local development overrides
local-config.js
dev-config.js
local.*

# Performance reports
reports/
benchmarks/
profiling/

# ==========================================
# EXCEPTIONS (Files to NOT ignore)
# ==========================================

# Keep important config files
!.gitignore
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!CHANGELOG.md

# Keep workflow files
!.github/
!.github/workflows/
!.github/workflows/*.yml
!.github/workflows/*.yaml

# Keep documentation
!docs/
!docs/*.md

# Keep sample/example files
!*.example
!*.sample
!.env.example

# ==========================================
# END OF .GITIGNORE
# ==========================================
