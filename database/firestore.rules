// ==========================================
// 11 AVATAR DIGITAL HUB
// Firestore Security Rules
// Version: 2.0 Enterprise
// ==========================================
// Purpose:
// - Role-based access control
// - Data isolation per client
// - Validation rules
// - Rate limiting awareness
// - Secure queries
// ==========================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get current user's profile document
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Get current user's role
    function getUserRole() {
      let profile = getUserProfile();
      return profile != null ? profile.role : null;
    }
    
    // Get current user's client ID
    function getUserClientId() {
      let profile = getUserProfile();
      return profile != null ? profile.clientId : null;
    }
    
    // Get current user's permissions
    function getUserPermissions() {
      let profile = getUserProfile();
      return profile != null ? profile.permissions : [];
    }
    
    // Check if user is platform-level
    function isPlatformUser() {
      let role = getUserRole();
      return role == 'platform_owner' || role == 'platform_super_admin' || role == 'admin';
    }
    
    // Check if user is client-level
    function isClientUser() {
      let role = getUserRole();
      return role == 'client_owner' || role == 'client_admin' || role == 'manager' || role == 'executive' || role == 'viewer';
    }
    
    // Check if user has specific permission
    function hasPermission(permission) {
      let permissions = getUserPermissions();
      return isPlatformUser() || 'all' in permissions || permission in permissions;
    }
    
    // Check if document belongs to user's client
    function belongsToClient() {
      let userClientId = getUserClientId();
      return userClientId == null || resource.data.clientId == userClientId;
    }
    
    // Check if incoming data has required fields
    function hasRequiredFields(required) {
      return required.hasAll(request.resource.data.keys());
    }
    
    // Validate email format
    function isValidEmail(email) {
      return email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    
    // Validate mobile (10 digits, Indian)
    function isValidMobile(mobile) {
      return mobile.matches('^[6-9]\\d{9}$');
    }
    
    // Validate date format (YYYY-MM-DD)
    function isValidDate(date) {
      return date.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }
    
    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      
      // READ: Platform users can read all. Client users can read own profile.
      allow read: if isAuthenticated() && (
        isPlatformUser() || 
        request.auth.uid == userId ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      // CREATE: Platform users can create any. New registration creates own.
      allow create: if isAuthenticated() && (
        isPlatformUser() ||
        request.auth.uid == userId
      ) && hasRequiredFields(['email', 'role']) &&
        request.resource.data.role in ['platform_owner', 'platform_super_admin', 'admin', 'client_owner', 'client_admin', 'manager', 'executive', 'viewer'];
      
      // UPDATE: Platform users can update any. Users can update own profile (limited).
      allow update: if isAuthenticated() && (
        isPlatformUser() ||
        request.auth.uid == userId
      ) && (
        // Users cannot change their own role
        request.auth.uid == userId && 
        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
      );
      
      // DELETE: Only platform_owner can delete users
      allow delete: if isAuthenticated() && getUserRole() == 'platform_owner';
    }
    
    // ==========================================
    // LEADS COLLECTION
    // ==========================================
    match /leads/{leadId} {
      
      // READ: Platform users see all. Client users see own client's leads.
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && (resource.data.clientId == getUserClientId() || resource.data.clientId == null))
      );
      
      // CREATE: Authenticated users with leads:create permission
      allow create: if isAuthenticated() && hasPermission('leads:create') && (
        isPlatformUser() || request.resource.data.clientId == getUserClientId()
      ) && hasRequiredFields(['name', 'mobile']) &&
        isValidMobile(request.resource.data.mobile);
      
      // UPDATE: Users with leads:edit permission
      allow update: if isAuthenticated() && hasPermission('leads:edit') && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      
      // DELETE: Users with leads:delete permission
      allow delete: if isAuthenticated() && hasPermission('leads:delete') && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
    }
    
    // ==========================================
    // CLIENTS COLLECTION
    // ==========================================
    match /clients/{clientId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      allow create: if isAuthenticated() && hasPermission('clients:create') && (
        isPlatformUser() || request.resource.data.clientId == getUserClientId()
      ) && hasRequiredFields(['name']);
      
      allow update: if isAuthenticated() && hasPermission('clients:edit') && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      
      allow delete: if isAuthenticated() && hasPermission('clients:delete') && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
    }
    
    // ==========================================
    // REVENUE COLLECTION
    // ==========================================
    match /revenue/{entryId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      allow create: if isAuthenticated() && hasPermission('revenue:add') && (
        isPlatformUser() || request.resource.data.clientId == getUserClientId()
      ) && hasRequiredFields(['client', 'amount', 'date']) &&
        request.resource.data.amount > 0 &&
        isValidDate(request.resource.data.date);
      
      allow update: if isAuthenticated() && hasPermission('revenue:edit') && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      
      allow delete: if isAuthenticated() && hasPermission('revenue:delete') && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
    }
    
    // ==========================================
    // PROJECTS COLLECTION
    // ==========================================
    match /projects/{projectId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      allow create: if isAuthenticated() && (
        isPlatformUser() || request.resource.data.clientId == getUserClientId()
      ) && hasRequiredFields(['name']);
      
      allow update: if isAuthenticated() && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // RETAINERS COLLECTION
    // ==========================================
    match /retainers/{retainerId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      allow create: if isAuthenticated() && (
        isPlatformUser() || request.resource.data.clientId == getUserClientId()
      );
      
      allow update: if isAuthenticated() && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // INVOICES COLLECTION
    // ==========================================
    match /invoices/{invoiceId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      allow create: if isAuthenticated() && hasRequiredFields(['number', 'client', 'amount']);
      
      allow update: if isAuthenticated() && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // TASKS COLLECTION
    // ==========================================
    match /tasks/{taskId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() ||
        (isClientUser() && resource.data.clientId == getUserClientId())
      );
      
      allow create: if isAuthenticated() && hasRequiredFields(['title']);
      
      allow update: if isAuthenticated();
      
      allow delete: if isAuthenticated();
    }
    
    // ==========================================
    // APPOINTMENTS COLLECTION
    // ==========================================
    match /appointments/{appointmentId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['title', 'with', 'date', 'time']);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ==========================================
    // CAMPAIGNS COLLECTION
    // ==========================================
    match /campaigns/{campaignId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['name']);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ==========================================
    // TRAININGS COLLECTION
    // ==========================================
    match /trainings/{trainingId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['name', 'attendee']);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ==========================================
    // REFERRALS COLLECTION
    // ==========================================
    match /referrals/{referralId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredFields(['clientName', 'name', 'mobile']) &&
        isValidMobile(request.resource.data.mobile);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // ==========================================
    // HISTORY COLLECTION
    // ==========================================
    match /history/{entryId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // NOTIFICATIONS COLLECTION
    // ==========================================
    match /notifications/{notificationId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // SETTINGS COLLECTION
    // ==========================================
    match /settings/{settingId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isPlatformUser();
      allow update: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && getUserRole() == 'platform_owner';
    }
    
    // ==========================================
    // BACKUPS COLLECTION
    // ==========================================
    match /backups/{backupId} {
      
      allow read: if isAuthenticated() && isPlatformUser();
      allow create: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && getUserRole() == 'platform_owner';
    }
    
    // ==========================================
    // ACTIVITY LOGS COLLECTION
    // ==========================================
    match /activityLogs/{logId} {
      
      allow read: if isAuthenticated() && isPlatformUser();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // WHATSAPP MESSAGES COLLECTION
    // ==========================================
    match /whatsappMessages/{messageId} {
      
      allow read: if isAuthenticated();
      allow create: if true; // Webhook creates messages
      allow update: if isAuthenticated();
    }
    
    // ==========================================
    // CHAT MESSAGES COLLECTION
    // ==========================================
    match /chatMessages/{messageId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }
    
    // ==========================================
    // SESSIONS COLLECTION
    // ==========================================
    match /sessions/{sessionId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // SUBSCRIPTIONS COLLECTION
    // ==========================================
    match /subscriptions/{subscriptionId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || resource.data.clientId == getUserClientId()
      );
      allow create: if isAuthenticated() && isPlatformUser();
      allow update: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // ROLES COLLECTION
    // ==========================================
    match /roles/{roleId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && getUserRole() == 'platform_owner';
    }
    
    // ==========================================
    // GLOBAL RULES
    // ==========================================
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
