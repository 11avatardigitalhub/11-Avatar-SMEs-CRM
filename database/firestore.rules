// ==========================================
// 11 AVATAR DIGITAL HUB
// Firestore Security Rules v3.0
// ==========================================
// Purpose:
// - Role-based access control (8-tier RBAC)
// - Multi-tenant data isolation per client
// - Field-level validation rules
// - Secure query enforcement
// - Platform & client role separation
// ==========================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get current user's profile document
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Get current user's role
    function getUserRole() {
      let profile = getUserProfile();
      return profile != null ? profile.role : null;
    }
    
    // Get current user's client ID (tenant)
    function getUserClientId() {
      let profile = getUserProfile();
      return profile != null ? profile.clientId : null;
    }
    
    // Get current user's permissions array
    function getUserPermissions() {
      let profile = getUserProfile();
      return profile != null ? profile.permissions : [];
    }
    
    // Check if user is platform-level (super_admin or admin)
    function isPlatformUser() {
      let role = getUserRole();
      return role == 'super_admin' || role == 'admin';
    }
    
    // Check if user is client/tenant-level
    function isTenantUser() {
      let role = getUserRole();
      return role != null && role != 'super_admin' && role != 'admin';
    }
    
    // Check if user has a specific permission
    function hasPermission(perm) {
      let permissions = getUserPermissions();
      // Platform users have all access
      if (isPlatformUser()) return true;
      // Check if 'all' or '*' wildcard exists
      if (permissions.hasAny(['all', '*'])) return true;
      // Check specific permission
      return permissions.hasAny([perm]);
    }
    
    // Check if document belongs to user's tenant/client
    function belongsToTenant() {
      let userClientId = getUserClientId();
      // If user has no clientId, allow (platform user)
      if (userClientId == null) return true;
      // Check document's clientId matches user's
      return resource.data.clientId == userClientId;
    }
    
    // Check if incoming write belongs to user's tenant
    function writeBelongsToTenant() {
      let userClientId = getUserClientId();
      if (userClientId == null) return true;
      return request.resource.data.clientId == userClientId;
    }
    
    // Check if document has required fields
    function hasRequiredFields(required) {
      return required.hasAll(request.resource.data.keys());
    }
    
    // Validate email format
    function isValidEmail(email) {
      return email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }
    
    // Validate Indian mobile number (10 digits, starts with 6-9)
    function isValidMobile(mobile) {
      return mobile.matches('^[6-9]\\d{9}$');
    }
    
    // Validate date format (YYYY-MM-DD)
    function isValidDate(date) {
      return date.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }
    
    // Validate role is one of the 8 allowed roles
    function isValidRole(role) {
      return role in ['super_admin', 'admin', 'manager', 'sales_lead', 'sales_executive', 'support_agent', 'accountant', 'viewer'];
    }
    
    // ==========================================
    // USERS COLLECTION
    // ==========================================
    match /users/{userId} {
      
      // READ: Platform users can read all. Users can read own. Tenant users read same tenant.
      allow read: if isAuthenticated() && (
        isPlatformUser() || 
        request.auth.uid == userId ||
        (isTenantUser() && resource.data.clientId == getUserClientId())
      );
      
      // CREATE: Platform users create any. Self-registration allowed.
      allow create: if isAuthenticated() && (
        isPlatformUser() ||
        request.auth.uid == userId
      ) && hasRequiredFields(['email', 'role']) &&
        isValidRole(request.resource.data.role);
      
      // UPDATE: Platform update any. Users update own (cannot change role).
      allow update: if isAuthenticated() && (
        isPlatformUser() ||
        (request.auth.uid == userId && 
         (!('role' in request.resource.data) || request.resource.data.role == resource.data.role))
      );
      
      // DELETE: Only super_admin can delete users
      allow delete: if isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // ==========================================
    // LEADS COLLECTION
    // ==========================================
    match /leads/{leadId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_leads') && (
        isPlatformUser() || writeBelongsToTenant()
      ) && hasRequiredFields(['name', 'mobile']) &&
        (request.resource.data.mobile == null || isValidMobile(request.resource.data.mobile));
      
      allow update: if isAuthenticated() && hasPermission('manage_leads') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && hasPermission('manage_leads') && (
        isPlatformUser() || belongsToTenant()
      );
    }
    
    // ==========================================
    // CLIENTS COLLECTION
    // ==========================================
    match /clients/{clientId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_clients') && (
        isPlatformUser() || writeBelongsToTenant()
      ) && hasRequiredFields(['name']);
      
      allow update: if isAuthenticated() && hasPermission('manage_clients') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && hasPermission('manage_clients') && (
        isPlatformUser() || belongsToTenant()
      );
    }
    
    // ==========================================
    // DEALS / PIPELINE COLLECTION
    // ==========================================
    match /deals/{dealId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_deals') && (
        isPlatformUser() || writeBelongsToTenant()
      ) && hasRequiredFields(['name', 'stage']);
      
      allow update: if isAuthenticated() && hasPermission('manage_deals') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && hasPermission('manage_deals') && (
        isPlatformUser() || belongsToTenant()
      );
    }
    
    // ==========================================
    // REVENUE COLLECTION
    // ==========================================
    match /revenue/{entryId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_revenue') && (
        isPlatformUser() || writeBelongsToTenant()
      ) && hasRequiredFields(['client', 'amount', 'date']) &&
        request.resource.data.amount > 0 &&
        isValidDate(request.resource.data.date);
      
      allow update: if isAuthenticated() && hasPermission('manage_revenue') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && hasPermission('manage_revenue') && (
        isPlatformUser() || belongsToTenant()
      );
    }
    
    // ==========================================
    // PROJECTS COLLECTION
    // ==========================================
    match /projects/{projectId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_projects') && (
        isPlatformUser() || writeBelongsToTenant()
      ) && hasRequiredFields(['name']);
      
      allow update: if isAuthenticated() && hasPermission('manage_projects') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // TASKS COLLECTION
    // ==========================================
    match /tasks/{taskId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasRequiredFields(['title']);
      
      allow update: if isAuthenticated();
      
      allow delete: if isAuthenticated();
    }
    
    // ==========================================
    // INVOICES COLLECTION
    // ==========================================
    match /invoices/{invoiceId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_invoices') && (
        isPlatformUser() || writeBelongsToTenant()
      ) && hasRequiredFields(['number', 'client', 'amount']);
      
      allow update: if isAuthenticated() && hasPermission('manage_invoices') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // PAYMENTS COLLECTION
    // ==========================================
    match /payments/{paymentId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && hasPermission('manage_payments') && (
        isPlatformUser() || writeBelongsToTenant()
      );
      
      allow update: if isAuthenticated() && hasPermission('manage_payments') && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // RETAINERS COLLECTION
    // ==========================================
    match /retainers/{retainerId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow create: if isAuthenticated() && (
        isPlatformUser() || writeBelongsToTenant()
      );
      
      allow update: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // NOTIFICATIONS COLLECTION
    // ==========================================
    match /notifications/{notificationId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // ACTIVITY LOGS COLLECTION
    // ==========================================
    match /activityLogs/{logId} {
      
      allow read: if isAuthenticated() && isPlatformUser();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // ERROR LOGS COLLECTION
    // ==========================================
    match /error_logs/{logId} {
      
      allow read: if isAuthenticated() && isPlatformUser();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // HISTORY COLLECTION
    // ==========================================
    match /history/{entryId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // WHATSAPP MESSAGES COLLECTION
    // ==========================================
    match /whatsappMessages/{messageId} {
      
      allow read: if isAuthenticated();
      allow create: if true; // Webhook creates messages
      allow update: if isAuthenticated();
    }
    
    // ==========================================
    // WHATSAPP CHATS COLLECTION
    // ==========================================
    match /whatsapp_chats/{chatId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }
    
    // ==========================================
    // SETTINGS COLLECTION
    // ==========================================
    match /settings/{settingId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isPlatformUser();
      allow update: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // ==========================================
    // BACKUPS COLLECTION
    // ==========================================
    match /backups/{backupId} {
      
      allow read: if isAuthenticated() && isPlatformUser();
      allow create: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // ==========================================
    // REPORTS COLLECTION
    // ==========================================
    match /reports/{reportId} {
      
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // SESSIONS COLLECTION
    // ==========================================
    match /sessions/{sessionId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || resource.data.userId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // SUBSCRIPTIONS COLLECTION
    // ==========================================
    match /subscriptions/{subscriptionId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      allow create: if isAuthenticated() && isPlatformUser();
      allow update: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // TENANTS COLLECTION
    // ==========================================
    match /tenants/{tenantId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || resource.data.id == getUserClientId()
      );
      allow create: if isAuthenticated() && isPlatformUser();
      allow update: if isAuthenticated() && isPlatformUser();
      allow delete: if isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // ==========================================
    // ROLES COLLECTION
    // ==========================================
    match /roles/{roleId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // ==========================================
    // EMAIL TEMPLATES COLLECTION
    // ==========================================
    match /email_templates/{templateId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // SMS TEMPLATES COLLECTION
    // ==========================================
    match /sms_templates/{templateId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // WORKFLOWS COLLECTION
    // ==========================================
    match /workflows/{workflowId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // INTEGRATIONS COLLECTION
    // ==========================================
    match /integrations/{integrationId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // WEBHOOKS COLLECTION
    // ==========================================
    match /webhooks/{webhookId} {
      
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isPlatformUser();
    }
    
    // ==========================================
    // FILES COLLECTION
    // ==========================================
    match /files/{fileId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        isPlatformUser() || (belongsToTenant() && resource.data.uploadedBy == request.auth.uid)
      );
    }
    
    // ==========================================
    // AUDIT LOGS COLLECTION
    // ==========================================
    match /audit_logs/{logId} {
      
      allow read: if isAuthenticated() && isPlatformUser();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && getUserRole() == 'super_admin';
    }
    
    // ==========================================
    // GST RECORDS COLLECTION
    // ==========================================
    match /gst_records/{recordId} {
      
      allow read: if isAuthenticated() && (
        isPlatformUser() || belongsToTenant()
      );
      allow create: if isAuthenticated() && hasPermission('manage_gst');
      allow update: if isAuthenticated() && hasPermission('manage_gst');
    }
    
    // ==========================================
    // GLOBAL DENY RULE
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}