{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "11 Avatar SMEs CRM",
  "short_name": "AvatarCRM",
  "description": "Enterprise SaaS CRM platform for small and medium enterprises with multi-tenant RBAC, WhatsApp integration, GST compliance, and full business automation.",
  "id": "/11-Avatar-SMEs-CRM/",
  "start_url": "/11-Avatar-SMEs-CRM/index.html",
  "scope": "/11-Avatar-SMEs-CRM/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "window-controls-overlay"],
  "orientation": "any",
  "theme_color": "#1A1A2E",
  "background_color": "#FFFFFF",
  "categories": [
    "business",
    "productivity",
    "finance",
    "utilities"
  ],
  "lang": "en-IN",
  "dir": "ltr",
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "capture_links": "new-client",
  "protocol_handlers": [
