  "share_target": {
    "action": "/11-Avatar-SMEs-CRM/index.html#/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "title": "11 Avatar SMEs CRM - Share",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "attachments",
          "accept": [
            "image/*",
            "application/pdf",
            "application/msword",
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "application/vnd.ms-excel",
